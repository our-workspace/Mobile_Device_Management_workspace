# ==============================================
# MDM Backend – Environment Variables
# ==============================================
# انسخ هذا الملف إلى .env وعدّل القيم

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------
# قاعدة البيانات (PostgreSQL)
# -----------------------------------------------
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/mdm_db"

# -----------------------------------------------
# Redis
# -----------------------------------------------
REDIS_URL="redis://localhost:6380"

# -----------------------------------------------
# JWT Secrets – غيّر هذه القيم في الإنتاج!
# -----------------------------------------------
JWT_SECRET="your-super-secret-key-change-in-production-min-32-chars"
JWT_DEVICE_EXPIRY="365d"
JWT_ADMIN_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# -----------------------------------------------
# Enrollment – التوكن المضمّن في الـ APK
# -----------------------------------------------
ENROLLMENT_TOKEN="your-enrollment-secret-change-me-very-secret"

# -----------------------------------------------
# File Storage
# -----------------------------------------------
FILE_STORAGE_PATH="./uploads"
FILE_STORAGE_MODE="local"    # local | s3

# S3 (فقط إذا كان FILE_STORAGE_MODE=s3)
# S3_BUCKET=mdm-backups
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------
# Heartbeat Settings
# -----------------------------------------------
HEARTBEAT_TTL_SECONDS=90
HEARTBEAT_INTERVAL_SECONDS=30
