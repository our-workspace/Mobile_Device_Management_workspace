<?xml version="1.0" encoding="utf-8"?>
<!--
    network_security_config.xml
    يسمح بـ HTTP (cleartext) على الشبكة المحلية فقط للتطوير.
    في الإنتاج يجب استخدام HTTPS وإزالة هذا الملف.
-->
<network-security-config>
    <!-- السماح بـ HTTP على عناوين الشبكة المحلية -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.34</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- باقي الاتصالات: HTTPS فقط -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
